# Local host DB URL for tools/tests outside Docker
DATABASE_URL=postgresql+asyncpg://user:userpass@127.0.0.1:5435/users

# PostgreSQL (used by docker-compose)
POSTGRES_USER=user
POSTGRES_PASSWORD=userpass
POSTGRES_DB=users
POSTGRES_HOST=user-db
POSTGRES_PORT=5432

# Auth service
# Replace with your own long random secret in production
AUTH_SECRET_KEY=change_me_to_a_long_random_secret
USER_SERVICE_URL=http://user-service:8000
REDIS_HOST=auth-redis
REDIS_PORT=6379
